---
import '../styles/atlas/tokens.css';
import '../styles/atlas/semantic.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/spline-sans-mono/400.css';
import '@fontsource/spline-sans-mono/500.css';
import FamilyBar from '../components/FamilyBar.astro';
import ProductNav from '../components/landing/ProductNav.astro';
import Hero from '../components/landing/Hero.astro';
import BetBand from '../components/landing/BetBand.astro';
import Capabilities from '../components/landing/Capabilities.astro';
import DiataxisMatrix from '../components/landing/DiataxisMatrix.astro';
import InstallBand from '../components/landing/InstallBand.astro';
import SiteFooter from '../components/landing/SiteFooter.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Omnia — the self-hostable AgentOS</title>
    <meta
      name="description"
      content="The operating system for production agents — self-hosted on Kubernetes, OCI, MCP, OpenTelemetry and Postgres. Author, prove, run, measure, and ship agents as installable bundles. Own the agents, rent the model."
    />
    <link rel="icon" href="/atlas/logo-omnia.svg" type="image/svg+xml" />
    <script is:inline>
      // Pre-hydration theme init: localStorage -> prefers-color-scheme.
      const t =
        localStorage.getItem('starlight-theme') ||
        (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      document.documentElement.dataset.theme = t;
    </script>
  </head>
  <body>
    <FamilyBar />
    <ProductNav />
    <main>
      <Hero />
      <BetBand />
      <Capabilities />
      <DiataxisMatrix />
      <InstallBand />
    </main>
    <SiteFooter />
    <style is:global>
      html {
        background: var(--bg-app);
        color-scheme: dark light;
      }
      body {
        margin: 0;
        font-family: var(--font-sans);
        background: var(--bg-app);
        color: var(--text-body);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      .atlas-inner {
        max-width: 1120px;
        margin: 0 auto;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
    </style>
  </body>
</html>
