# monaco-editor is aliased to @codingame/monaco-vscode-editor-api (v8.x), which
# monaco-languageclient v8 requires. @monaco-editor/react@4 still declares a stale
# peer range of monaco-editor ">= 0.25.0 < 1", so strict peer resolution (npm ci)
# errors even though the @codingame editor-api is API-compatible. Accept it.
legacy-peer-deps=true
