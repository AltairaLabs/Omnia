# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include Go source files (but not *_test.go)
!**/*.go
**/*_test.go

# Re-include Go module files
!go.mod
!go.sum

# Re-include embedded schema files for go:embed
!internal/schema/*.json

# Re-include SQL migration files for go:embed (session-api)
!internal/session/postgres/migrations/*.sql

# Re-include OpenAPI specs for go:embed (session-api and memory-api docs)
!internal/session/api/openapi.yaml
!internal/memory/api/openapi.yaml

# Re-include embedded license public key for go:embed
!pkg/
!pkg/license/
!pkg/license/keys/
!pkg/license/keys/public.pem

# Re-include enterprise (ee/) directory - use multiple patterns to ensure all subdirs are included
!ee/
!ee/*
!ee/*/*
!ee/*/*/*
!ee/*/*/*/*
!ee/*/*/*/*/*

# Re-include local PromptKit source for development builds (Go source only)
# The !**/*.go and !go.mod/!go.sum patterns above already match promptkit-local,
# but we need explicit directory includes so Docker copies the directory structure.
# WARNING: When a new module is added to promptkit-local (new go.mod), add its
# *.go, go.mod, and go.sum patterns here — otherwise Docker builds will fail
# with "no such file or directory" errors for the missing module.
!promptkit-local/pkg/**/*.go
!promptkit-local/pkg/go.mod
!promptkit-local/pkg/go.sum
!promptkit-local/runtime/**/*.go
!promptkit-local/runtime/go.mod
!promptkit-local/runtime/go.sum
!promptkit-local/sdk/**/*.go
!promptkit-local/sdk/go.mod
!promptkit-local/sdk/go.sum
!promptkit-local/runtime/prompt/schema/*.json
!promptkit-local/server/a2a/**/*.go
!promptkit-local/server/a2a/go.mod
!promptkit-local/server/a2a/go.sum
!promptkit-local/tools/arena/**/*.go
!promptkit-local/tools/arena/go.mod
!promptkit-local/tools/arena/go.sum
!promptkit-local/tools/packc/**/*.go
!promptkit-local/tools/packc/go.mod
!promptkit-local/tools/packc/go.sum
!promptkit-local/tools/arena/templates/builtin/*
!promptkit-local/tools/arena/render/templates/*.tmpl
