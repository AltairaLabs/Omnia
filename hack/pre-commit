#!/usr/bin/env bash
#
# Pre-commit hook for Omnia
#
# FAST checks only — target ≤15s on warm caches. The expensive checks
# (full test suite, coverage thresholds, generated-code sync, helm
# validation) live in hack/pre-push, which runs once per push instead
# of once per commit.
#
# What runs here:
#   - gofmt / goimports (format)
#   - go vet
#   - golangci-lint --fast (subset of linters that don't require type info)
#   - go build ./...
#   - Dashboard ESLint + typecheck
#   - PII log check (string grep)
#   - Observability boundary check (string grep)
#
# What runs in pre-push instead:
#   - Full golangci-lint
#   - Full test suite with coverage (including testcontainers integration)
#   - Per-line coverage check on changed lines (matches SonarCloud)
#   - Generated-code sync (manifests, chart CRDs, dashboard types)
#   - Helm chart validation
#
# To skip this hook: git commit --no-verify
#
# Installation:
#   ln -sf ../../hack/pre-commit .git/hooks/pre-commit
#   ln -sf ../../hack/pre-push   .git/hooks/pre-push
#

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_info()   { echo -e "${BLUE}ℹ ${NC}$1"; }
print_success(){ echo -e "${GREEN}✓${NC} $1"; }
print_warning(){ echo -e "${YELLOW}⚠${NC} $1"; }
print_error()  { echo -e "${RED}✗${NC} $1"; }
print_header() {
	echo ""
	echo -e "${BLUE}═══════════════════════════════════════════════════${NC}"
	echo -e "${BLUE}  $1${NC}"
	echo -e "${BLUE}═══════════════════════════════════════════════════${NC}"
}

print_header "Pre-Commit Checks (fast)"
print_info "Heavy checks (tests, coverage, codegen sync, helm) run in pre-push"

CHECKS_FAILED=0
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
STAGED_DASHBOARD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^dashboard/.*\.\(ts\|tsx\|js\|jsx\)$' || true)
STAGED_OPENAPI=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^api/openapi/openapi\.yaml$' || true)
STAGED_ROUTES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^dashboard/src/app/api/.*/route\.ts$' || true)

#
# 0. OpenAPI spec ↔ dashboard route drift guard.
#    Runs whenever the spec OR a dashboard route changes, so the spec can
#    never document an endpoint that no route handler implements.
#
if [ -n "$STAGED_OPENAPI" ] || [ -n "$STAGED_ROUTES" ]; then
	print_header "Checking OpenAPI spec matches dashboard routes"
	if command -v python3 &>/dev/null; then
		if python3 "$REPO_ROOT/hack/check-openapi-routes.py"; then
			print_success "OpenAPI routes check passed"
		else
			print_error "OpenAPI spec documents routes/methods that don't exist"
			CHECKS_FAILED=1
		fi
	else
		print_error "python3 not found; cannot run OpenAPI routes check"
		CHECKS_FAILED=1
	fi
fi

if [ -z "$STAGED_GO_FILES" ] && [ -z "$STAGED_DASHBOARD_FILES" ]; then
	if [ $CHECKS_FAILED -ne 0 ]; then
		print_error "Pre-commit checks failed!"
		exit 1
	fi
	print_info "No Go or dashboard files staged. Skipping remaining checks."
	exit 0
fi

#
# Dashboard (fast checks only — tests run in pre-push)
#
if [ -n "$STAGED_DASHBOARD_FILES" ]; then
	print_info "Found $(echo "$STAGED_DASHBOARD_FILES" | wc -l | tr -d ' ') dashboard file(s) to check"

	if ! command -v npm &>/dev/null; then
		print_warning "npm is not installed, skipping dashboard checks"
	else
		if [ ! -d "$REPO_ROOT/dashboard/node_modules" ]; then
			print_info "Installing dashboard dependencies..."
			(cd "$REPO_ROOT/dashboard" && npm ci --silent)
		fi

		print_header "Dashboard: ESLint"
		if (cd "$REPO_ROOT/dashboard" && npm run lint --silent 2>&1); then
			print_success "ESLint passed"
		else
			print_error "ESLint failed"
			CHECKS_FAILED=1
		fi

		print_header "Dashboard: TypeScript"
		if (cd "$REPO_ROOT/dashboard" && npm run typecheck --silent 2>&1); then
			print_success "TypeScript check passed"
		else
			print_error "TypeScript check failed"
			CHECKS_FAILED=1
		fi
	fi
fi

if [ -z "$STAGED_GO_FILES" ]; then
	# Dashboard-only commit; we're done.
	print_header "Summary"
	if [ $CHECKS_FAILED -eq 0 ]; then
		print_success "All pre-commit checks passed!"
		exit 0
	fi
	print_error "Pre-commit checks failed!"
	exit 1
fi

print_info "Found $(echo "$STAGED_GO_FILES" | wc -l | tr -d ' ') Go file(s) to check"

#
# 1. gofmt / goimports
#
print_header "Checking Formatting"
UNFORMATTED=$(gofmt -l $STAGED_GO_FILES 2>/dev/null || true)
if [ -n "$UNFORMATTED" ]; then
	print_error "These files are not gofmt'd:"
	echo "$UNFORMATTED" | sed 's/^/  - /'
	print_info "Run: gofmt -w $UNFORMATTED"
	CHECKS_FAILED=1
else
	print_success "All files properly formatted"
fi

#
# 2. go vet on changed-files' packages (with e2e build tag so e2e
#    files don't error with "build constraints exclude all Go files")
#
# Filters to staged packages — module-wide vet is too slow for the
# per-commit budget. Pre-push runs full-module vet.
#
VET_PACKAGES=$(echo "$STAGED_GO_FILES" | xargs -n1 dirname 2>/dev/null | sort -u | sed 's|^|./|' | tr '\n' ' ')
print_header "Running go vet"
if go vet -tags=e2e $VET_PACKAGES 2>&1; then
	print_success "go vet passed"
else
	print_error "go vet failed"
	CHECKS_FAILED=1
fi

#
# 3. golangci-lint --fast-only --new-from-rev on changed packages
#
# `--new-from-rev=origin/main` filters to issues introduced by THIS
# branch's diff vs main, so pre-existing complexity/dupl/lll issues
# in adjacent files (or files in the same package) don't surface
# here. Pre-push runs full module lint and catches everything.
#
# Falls back gracefully when origin/main isn't fetched yet
# (golangci-lint silently disables --new-from-rev and lints everything;
# we accept that as a worst-case for fresh clones).
#
print_header "Linting Changed Files (fast linters, new-code-only)"
if command -v golangci-lint &>/dev/null; then
	LINT_NEW_FROM=$(git merge-base origin/main HEAD 2>/dev/null || echo "")
	NEW_FROM_ARG=""
	if [ -n "$LINT_NEW_FROM" ]; then
		NEW_FROM_ARG="--new-from-rev=$LINT_NEW_FROM"
	fi
	if golangci-lint run --fast-only --timeout=60s --build-tags=e2e $NEW_FROM_ARG $VET_PACKAGES 2>&1; then
		print_success "Lint passed"
	else
		print_error "Lint failed"
		CHECKS_FAILED=1
	fi
else
	print_warning "golangci-lint not installed; skipping (will run in pre-push)"
fi

#
# 4. PII log check — fast grep, no compilation needed
#
print_header "Checking Logs for PII"
PII_HITS=""
for f in $STAGED_GO_FILES; do
	# Skip test files
	[[ "$f" == *_test.go ]] && continue
	# Look for risky patterns: logging raw user IDs / emails without hashing
	if grep -nE '\.Info\(.*("user_id"|"userID"|"email"|"user"\s*:\s*[a-zA-Z_]+)' "$f" 2>/dev/null |
		grep -vE 'HashID\(|hashUserID\(|redact' >/dev/null; then
		PII_HITS="$PII_HITS\n$f"
	fi
done
if [ -n "$PII_HITS" ]; then
	print_warning "Possible raw user-id logging detected (manual review):"
	echo -e "$PII_HITS" | sed 's/^/  - /'
	print_info "Use logging.HashID() before persisting user IDs"
	# Soft warning — doesn't fail the commit
else
	print_success "PII log check: clean"
fi

#
# 5. Observability boundary check — product hooks must not import Prom
#
print_header "Checking Observability Boundaries"
BOUNDARY_VIOLATIONS=""
for f in $STAGED_DASHBOARD_FILES; do
	REL_FILE="${f#dashboard/}"
	case "$REL_FILE" in
	src/hooks/use-eval-*.ts | src/hooks/use-eval-*.tsx | src/hooks/use-*-cost.ts | src/hooks/use-*-cost.tsx | src/hooks/use-provider-*.ts | src/hooks/use-provider-*.tsx)
		if grep -lE "prometheus-service|prometheus-proxy|@/lib/prometheus" "$f" 2>/dev/null; then
			BOUNDARY_VIOLATIONS="$BOUNDARY_VIOLATIONS\n$f"
		fi
		;;
	esac
done
if [ -n "$BOUNDARY_VIOLATIONS" ]; then
	print_error "Product-class hooks must not import Prometheus (see CLAUDE.md § Observability Boundaries):"
	echo -e "$BOUNDARY_VIOLATIONS" | sed 's/^/  - /'
	CHECKS_FAILED=1
else
	print_success "Observability boundary check passed"
fi

#
# 5b. File length guardrail — staged files must not exceed the length
#     threshold (ratchet via hack/file-length-baseline.txt). See issue #1325.
#
if [ -n "$STAGED_GO_FILES" ] || [ -n "$STAGED_DASHBOARD_FILES" ]; then
	print_header "Checking File Length"
	if bash "$REPO_ROOT/hack/check-file-length.sh" --staged; then
		print_success "File length guardrail passed"
	else
		print_error "File length guardrail failed (see issue #1325)"
		CHECKS_FAILED=1
	fi
fi

#
# 6. go build — catches type errors fast
#
print_header "Building"
if go build ./... 2>&1; then
	print_success "Build successful"
else
	print_error "Build failed"
	CHECKS_FAILED=1
fi

print_header "Summary"
if [ $CHECKS_FAILED -eq 0 ]; then
	print_success "All pre-commit checks passed!"
	print_info "Push will trigger the heavier pre-push checks (tests, coverage, codegen sync)."
	exit 0
fi
echo ""
print_error "Pre-commit checks failed!"
echo ""
print_info "Options:"
print_info "  1. Fix the issues above and try again"
print_info "  2. Bypass with 'git commit --no-verify' (NOT recommended)"
exit 1
